# Copy this file to ".env" and fill in your own values.
# .env is gitignored — your keys stay local and are never committed.

# ── Football (football-data.org, free tier) ──────────────────────────────
# Register for a free key: https://www.football-data.org/client/register
FOOTBALL_API_KEY=

# ── Clash Royale (official Supercell API) ────────────────────────────────
# Create a key at https://developer.clashroyale.com
# The key is locked to the IP address you whitelist when creating it — use
# your home IP. If your IP changes, make a new key.
CR_API_KEY=
# Your in-game player tag. It MUST be quoted, because the leading '#' would
# otherwise be read as a comment in a .env file.
CR_PLAYER_TAG="#XXXXXXX"

# Weather (Open-Meteo) needs no key. To change the city, edit the coordinates
# in src/main/integrations/weather.ts and the "Evanston" labels in
# src/renderer/src/components/Topbar.tsx — see the README.
